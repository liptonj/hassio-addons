{
  "name": "Jandy TCX Client",
  "version": "2026.5.5",
  "slug": "tcx-client",
  "init": false,
  "description": "Jandy TCX Client for to interact with Home Assistant",
  "webui": "http://[HOST]:[PORT:5050]",
  "url": "https://github.com/liptonj/hassio-addons/tree/master/tcx",
  "stage": "experimental",
  "homeassistant_api": true,
  "arch": [
    "amd64"
  ],
  "startup": "system",
  "boot": "auto",
  "ports": {
    "5050/tcp": "5050"
  },
  "ports_description": {
    "5050/tcp": "Web interface"
  },
  "options": {
    "log_level": "info",
    "JANDY_USERNAME": "user@email.com",
    "JANDY_PASSWORD": "<Password>",
    "WS_TRACE": "False",
    "AUTO_RECONNECT": "True",
    "RECONNECT_TIMER": "60",
    "PING_TIMER": "60",
    "POOL_SHAPE": "rectangular",
    "POOL_LENGTH_FT": "0",
    "POOL_WIDTH_FT": "0",
    "POOL_DEPTH_FT": "0",
    "POOL_VOLUME": "0",
    "HEATER_BTU": "0",
    "OUTDOOR_TEMP_ENTITY": ""
  },
  "schema": {
    "log_level": "list(crit|warn|error|info|debug)",
    "JANDY_USERNAME": "str",
    "JANDY_PASSWORD": "str",
    "WS_TRACE": "list(True|False)",
    "AUTO_RECONNECT": "list(True|False)",
    "RECONNECT_TIMER": "str?",
    "PING_TIMER": "str?",
    "POOL_SHAPE": "list(rectangular|oval|round|kidney)?",
    "POOL_LENGTH_FT": "str?",
    "POOL_WIDTH_FT": "str?",
    "POOL_DEPTH_FT": "str?",
    "POOL_VOLUME": "str?",
    "HEATER_BTU": "list(100000|150000|200000|250000|300000|350000|400000|500000)?",
    "OUTDOOR_TEMP_ENTITY": "str?"
  }
}
